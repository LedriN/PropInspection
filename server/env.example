# MongoDB Configuration
# Base URI without database name - the system will create separate databases for each user
MONGODB_URI=mongodb://localhost:27017
# For MongoDB Atlas (cloud), use format like:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net?retryWrites=true&w=majority

# The system will automatically create:
# - propinspection_users (for user accounts)
# - {username} (for each user's data, e.g., ledrinushi, johnsmith, etc.)

# Example with special characters in password (URL encoded):
# Password: ledriPropinspection@!.
# URL encoded: ledriPropinspection%40%21.
# MONGODB_URI=mongodb+srv://username:ledriPropinspection%40%21.@cluster.mongodb.net?retryWrites=true&w=majority

# MongoDB Connection Pool Settings (to prevent exceeding 500 connection limit)
# Main database connection pool
MONGO_MAX_POOL=5
MONGO_MIN_POOL=1

# Tenant database connection pool (per user database)
MONGO_TENANT_MAX_POOL=3
MONGO_TENANT_MIN_POOL=0

# Server Configuration
PORT=5000
NODE_ENV=development

# JWT Configuration (if needed for authentication)
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRE=7d

# Email Configuration (Resend)
RESEND_API_KEY=re_ixf3sUDZ_NhHarKTeEXV3GsUwNYn7o1ZN
RESEND_FROM=Kurz Immobilien <noreply@kurz-immobilien.ch>

# Other environment variables
# Add any other configuration variables here
